{% extends 'base.html.twig' %}

{% block title %}WorkTogether — Abonnement d'unités{% endblock %}

{% block navbar %}
<header class="site-header">
  <div class="inner container">
    <a class="brand" href="{{ path('app_home') }}">
      <span class="logo" aria-hidden="true"></span>
      WorkTogether
    </a>

    <nav class="nav" aria-label="Main navigation">
      <a href="#features">Fonctionnalités</a>
      <a href="#how">Comment ça marche</a>
      <a href="{{ path('app_order_new') }}">Commander</a>
    </nav>

    <div class="nav-actions">
      <a class="btn" href="{{ path('app_register') }}">Inscription</a>
      <a class="btn" href="{{ path('app_login') }}">Connexion</a>
    </div>
  </div>
</header>
{% endblock %}

{% block body %}

<section class="hero">
    <div class="content container">
        <span class="kicker">Service d'abonnement</span>
        <h1>Accédez à des <span class="highlight">unités</span> à la demande — Abonnez, regardez, utilisez.</h1>
        <p class="lead">WorkTogether vous propose un système d'abonnement simple pour obtenir des unités, attribuées à votre compte et utilisables immédiatement. Planifiez, consommez, et gérez vos unités depuis votre dashboard.</p>

        <div class="cta">
            <a class="btn-primary" href="{{ path('app_register') }}">Créer un compte</a>
            <a class="btn-ghost" href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>

    <div class="hero-visual">
        <div class="card">
            <!-- Example visual: stats / preview -->
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                <div>
                    <strong style="font-size:1.1rem;display:block">Votre compte</strong>
                    <small style="color:var(--muted)">Statistiques en temps réel</small>
                </div>
                <div style="text-align:right">
                    <div style="font-weight:800;font-size:1.4rem">24</div>
                    <div style="font-size:0.85rem;color:var(--muted)">unités restantes</div>
                </div>
            </div>

            <svg width="100%" height="120" viewBox="0 0 600 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M0 80 C120 20 240 120 360 60 C480 0 600 80 720 40" stroke="#8be0c4" stroke-width="3" fill="none" stroke-linecap="round"/>
            </svg>
        </div>
    </div>
</section>

<section class="offers-section">
    <div class="container">
        <h2 style="text-align:center;margin-bottom:1rem">Nos Offres</h2>

        {% if offers is empty %}
            <p class="small-muted" style="text-align:center">Aucune offre disponible pour le moment. Revenez bientôt.</p>
        {% else %}
            <div class="offers-grid" role="list">
                {% for offer in offers %}
                    <article class="offer-card" role="listitem" aria-labelledby="offer-{{ offer.id }}" style="--i:{{ loop.index0 }};">
                        <div class="offer-thumb" aria-hidden="true"></div>

                        <div class="offer-top">
                            <div>
                                <h3 id="offer-{{ offer.id }}" class="offer-name">{{ offer.nameOffer|default('Offre') }}</h3>
                                {# l'entité Offer ne contient pas de description; on peut afficher min/max unités #}
                                <p class="offer-desc small-muted">
                                    {% if offer.minUnits and offer.maxUnits %}
                                        {{ offer.minUnits }} – {{ offer.maxUnits }} unités
                                    {% elseif offer.minUnits %}
                                        À partir de {{ offer.minUnits }} unités
                                    {% elseif offer.maxUnits %}
                                        Jusqu'à {{ offer.maxUnits }} unités
                                    {% else %}
                                        Aucun minimum ni maximum
                                    {% endif %}
                                </p>
                            </div>

                            <div style="display:flex;flex-direction:column;gap:.4rem;align-items:end">
                                {% if offer.discountPercent is not null and (offer.discountPercent + 0) > 0 %}
                                    <div class="offer-badge" data-type="discount" aria-hidden="true">-{{ (offer.discountPercent + 0)|round(2) }}%</div>
                                {% endif %}

                                {% if not offer.isActive %}
                                    <div class="offer-badge" data-type="inactive">Inactive</div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="offer-meta">
                            <div class="offer-price" aria-label="information sur l'offre">
                                {% if offer.discountPercent is not null and (offer.discountPercent + 0) > 0 %}
                                    Offre: -{{ (offer.discountPercent + 0)|round(2) }}%
                                {% else %}
                                    Offre standard
                                {% endif %}
                            </div>
                        </div>

                        <div class="offer-actions">
                            {% if offer.isActive %}
                                <a class="btn-primary" href="{{ path('app_order_new', {'offerId': offer.id}) }}" aria-label="Commander {{ offer.nameOffer|default('cette offre') }}">Commander</a>
                            {% else %}
                                <button class="btn-ghost" disabled aria-disabled="true" title="Offre inactive" aria-label="Offre inactive">Commander</button>
                            {% endif %}
                            <a class="btn-ghost" href="{{ path('app_order') }}">Mes commandes</a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<section id="features" class="features container">
    <h2 style="text-align:center;margin-bottom:1rem">Fonctionnalités</h2>
    <div class="features-grid">
        <div class="feature">
            <div class="icon">A</div>
            <h3>Consommation flexible</h3>
            <p>Utilisez vos unités quand vous le souhaitez. Elles sont automatiquement assignées et gérées depuis votre compte.</p>
        </div>
        <div class="feature">
            <div class="icon">D</div>
            <h3>Gestion centralisée</h3>
            <p>Un tableau de bord clair pour suivre vos commandes, unités restantes et historique.</p>
        </div>
        <div class="feature">
            <div class="icon">S</div>
            <h3>Sécurité & fiabilité</h3>
            <p>Authentification, gestion des utilisateurs et journaux d'activité pour garder le contrôle.</p>
        </div>
    </div>
</section>

<section id="how" class="how">
    <div class="container">
        <h2>Comment ça marche</h2>
        <div class="steps">
            <div class="step">
                <strong>1. Inscrivez-vous</strong>
                <p>Créez un compte en quelques secondes.</p>
            </div>
            <div class="step">
                <strong>2. Commandez</strong>
                <p>Choisissez une offre et sélectionnez le nombre d'unités.</p>
            </div>
            <div class="step">
                <strong>3. Consommez</strong>
                <p>Les unités sont allouées et prêtes à l'utilisation.</p>
            </div>
        </div>
    </div>
</section>

<footer class="site-footer">
    <div class="container">
        <div>© {{ "now"|date('Y') }} WorkTogether — Tous droits réservés</div>
        <div style="margin-top:.5rem;"><a href="{{ path('app_register') }}">Inscription</a> · <a href="{{ path('app_login') }}">Connexion</a> · <a href="{{ path('app_order') }}">Mes commandes</a></div>
    </div>
</footer>

<script>
    // Small UX: scroll to features when clicking nav links
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('a[href^="#"]').forEach(function (el){
            el.addEventListener('click', function (e){
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) target.scrollIntoView({behavior:'smooth',block:'start'});
            });
        });
    });
</script>

{% endblock %}
