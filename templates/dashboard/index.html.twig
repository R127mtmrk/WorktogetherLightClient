{% extends 'base.html.twig' %}

{% block title %}Mon dashboard - Offres & Commandes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
{% endblock %}

{% block body %}
<div class="container">
  <div class="dashboard-header">
    <div>
      <h1 class="dashboard-title">Bienvenue sur votre dashboard</h1>
      <div class="dashboard-sub">Offres récentes et vos commandes</div>
    </div>
  </div>

  <div class="dashboard-grid">
    <div>
      <section class="card">
        <h2 style="font-size:1.15rem;margin-bottom:.75rem;">Nouvelles offres</h2>
        <div class="offers">
          {% if offers is empty %}
            <div style="color:var(--muted);">Aucune offre pour le moment.</div>
          {% else %}
            {% for offer in offers %}
              <div class="offer-row">
                <div class="offer-info">
                  <div>
                    <div class="offer-name">
                      {% if offer.getPrice is not null %}
                        Offre - {{ offer.getPrice|number_format(2, '.', ' ') }} €
                      {% else %}
                        Offre #{{ offer.id }}
                      {% endif %}
                    </div>
                    <div class="offer-meta">Min units: {{ offer.getMinUnits ?: '-' }}</div>
                  </div>
                </div>
                <div style="text-align:right">
                  <div style="margin-bottom:.4rem;font-weight:700">{{ offer.getPrice is not null ? (offer.getPrice|number_format(2, '.', ' ')) ~ ' €' : 'Contact' }}</div>
                  <a href="{{ path('app_order_new') }}?offer={{ offer.id }}" class="btn btn-primary">Commander</a>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </section>
    </div>

    <div>
      <section class="card">
        <h2 style="font-size:1.15rem;margin-bottom:.75rem;">Vos dernières commandes</h2>

        {% if orders is empty %}
            <p>Vous n'avez aucune commande pour le moment.</p>
        {% else %}
            <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Offre</th>
                        <th>Quantité</th>
                        <th>Prix unitaire</th>
                        <th>Total</th>
                        <th>Paiement annuel</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td>{{ order.getCreatedAt ? order.getCreatedAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>
                                {% if order.getOffer %}
                                    {% set o = order.getOffer %}
                                    {% if o.getPrice is not null %}
                                        Offre - {{ o.getPrice|number_format(2, '.', ' ') }} €
                                    {% else %}
                                        Offre #{{ o.id }}
                                    {% endif %}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>{{ order.getQuantity }}</td>
                            <td>{{ order.getUnitPrice is not null ? (order.getUnitPrice|number_format(2, '.', ' ')) ~ ' €' : '-' }}</td>
                            <td>{{ order.getTotal is not null ? (order.getTotal|number_format(2, '.', ' ')) ~ ' €' : '-' }}</td>
                            <td>{{ order.isAnnualPayment ? 'Oui' : 'Non' }}</td>
                            <td><a class="btn-outline" href="{{ path('app_order') }}">Voir</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
      </section>
    </div>
  </div>
</div>
{% endblock %}
