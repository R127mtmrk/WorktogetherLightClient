{% extends 'base.html.twig' %}

{% block title %}Mon dashboard - Offres & Commandes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('css/orders-list-light.css') }}">
{% endblock %}

{% block body %}
<div class="container">
  <div class="dashboard-header">
    <div>
      <h1 class="dashboard-title">Bienvenue sur votre dashboard</h1>
      <div class="dashboard-sub">Offres récentes et vos commandes</div>
    </div>
  </div>

  <div class="dashboard-grid">
    <div>
      <section class="card">
        <h2 style="font-size:1.15rem;margin-bottom:.75rem;">Nouvelles offres</h2>
        <div class="offers">
          {% if offers is empty %}
            <div style="color:var(--muted);">Aucune offre pour le moment.</div>
          {% else %}
            {% for offer in offers %}
              <div class="offer-row">
                <div class="offer-info">
                  <div>
                    <div class="offer-name">
                        Offre #{{ offer.id }}
                        {% if offer.getDiscountPercent() is not null %}
                            <span class="offer-discount">-{{ offer.getDiscountPercent|number_format(2, '.', ' ') }} %</span>
                        {% endif %}
                    </div>
                    <div class="offer-meta">Nombre minimal d'unités: {{ offer.getMinUnits ?: '-' }}</div>
                  </div>
                </div>
                <div style="text-align:right">
                  <div style="margin-bottom:.4rem;font-weight:700">Réduction : {{ offer.getDiscountPercent is not null ? (offer.getDiscountPercent|number_format(2, '.', ' ')) ~ ' %' : 'Contact' }}</div>
                  <a href="{{ path('app_order_new') }}?offer={{ offer.id }}" class="btn btn-primary">Commander</a>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </section>
    </div>

    <div>
      <section class="card table-card">
        <h2 style="font-size:1.15rem;margin-bottom:.75rem;">Vos dernières commandes</h2>

        {% if orders is empty %}
            <p>Vous n'avez aucune commande pour le moment.</p>
        {% else %}
            <div class="table-wrap">
            <table class="table table-light">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Quantité</th>
                        <th>Total</th>
                        <th>Paiement annuel</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td data-label="Date">{{ order.getCreatedAt ? order.getCreatedAt|date('d/m/Y') : '-' }}</td>
                            <td data-label="Quantité">{{ order.getQuantity }}</td>
                            <td data-label="Total">{{ order.getTotal is not null ? (order.getTotal|number_format(2, '.', ' ')) ~ '€' : '-' }}</td>
                            <td data-label="Paiement annuel">{{ order.isAnnualPayment ? 'Oui' : 'Non' }}</td>
                            <td data-label="Actions"><a class="btn-outline" href="{{ path('app_order') }}">Voir</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
      </section>
    </div>
  </div>
</div>
{% endblock %}
