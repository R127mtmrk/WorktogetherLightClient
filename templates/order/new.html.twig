{% extends 'base.html.twig' %}

{% block title %}Nouvelle commande{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/order.css') }}">
{% endblock %}

{% block body %}
<div class="container">
    <div class="order-card">
        <div class="order-header">
            <div>
                <div class="order-title">Nouvelle commande</div>
                <div class="order-sub">Choisissez une offre et la quantité souhaitée.</div>
            </div>
            <div class="available-badge">Dispo : <span id="available-count">{{ available }}</span></div>
        </div>

        <div class="form-grid">
            <div class="form-column">
                {{ form_start(form) }}

                <div class="form-row">
                    <label for="{{ form.offer.vars.id }}">Offre</label>
                    {{ form_widget(form.offer) }}
                </div>

                <div class="form-row">
                    <label for="{{ form.quantity.vars.id }}">Quantité</label>
                    {{ form_widget(form.quantity) }}
                </div>

                <div class="form-row">
                    <label for="{{ form.annualPayment.vars.id }}">Paiement annuel</label>
                    {{ form_widget(form.annualPayment) }}
                </div>

                <div class="form-row">
                    <label for="{{ form.discountPercent.vars.id }}">Pourcentage de réduction (facultatif)</label>
                    {{ form_widget(form.discountPercent) }}
                </div>

                <div class="form-row note">
                    <label for="{{ form.unitPrice.vars.id }}">Prix unitaire (calculé)</label>
                    {{ form_widget(form.unitPrice) }}
                </div>

                <div class="form-row note">
                    <label for="{{ form.total.vars.id }}">Total (calculé)</label>
                    {{ form_widget(form.total) }}
                </div>

                <div class="form-row">
                    <label for="{{ form.createdAt.vars.id }}">Date</label>
                    {{ form_widget(form.createdAt) }}
                </div>

                <div class="form-row">
                    {{ form_widget(form.simulate) }}
                    <label for="{{ form.simulate.vars.id }}">Simulation (aucune modification en base)</label>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit">Vérifier / Simuler</button>
                    <a class="btn btn-ghost" href="{{ path('app_order') }}">Annuler</a>
                </div>

                {{ form_end(form) }}

                {# Si le contrôleur a retourné 'simulate' = true, proposer un formulaire POST vers la route de confirmation
                   pour les utilisateurs sans JS : envoi des champs essentiels en POST pour afficher la page de confirmation. #}
                {% if simulate is defined and simulate %}
                    <div class="simulate-result">
                        <h3>Simulation prête</h3>
                        <p>Total simulé : <strong>{{ simulatedTotal is defined ? simulatedTotal : '-' }}</strong> €</p>
                        <form method="post" action="{{ path('app_order_confirm') }}" style="margin-top:1rem">
                            <input type="hidden" name="offer" value="{{ form.offer.vars.value is defined ? form.offer.vars.value : (offers|first ? offers|first.id : '') }}" />
                            <input type="hidden" name="quantity" value="{{ form.quantity.vars.value }}" />
                            <input type="hidden" name="unitPrice" value="{{ form.unitPrice.vars.value }}" />
                            <input type="hidden" name="annualPayment" value="{{ form.annualPayment.vars.value ? 1 : 0 }}" />
                            <input type="hidden" name="discountPercent" value="{{ form.discountPercent.vars.value }}" />
                            <input type="hidden" name="total" value="{{ simulatedTotal is defined ? simulatedTotal : form.total.vars.value }}" />
                            <input type="hidden" name="createdAt" value="{{ form.createdAt.vars.value }}" />
                            <input type="hidden" name="simulate" value="1" />

                            <button class="btn btn-primary" type="submit">Confirmer la transaction (simulate)</button>
                            <a class="btn btn-ghost" href="{{ path('app_order_new') }}">Retour</a>
                        </form>

                        {% if simulatedUnits is defined and simulatedUnits is not empty %}
                            <div style="margin-top:.5rem">
                                <strong>Unités proposées :</strong>
                                <ul>
                                    {% for id in simulatedUnits %}
                                        <li>Unit #{{ id }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}

            </div>

            <aside class="side-column">
                <div class="simulation-card">
                    <div class="helper">Simulation & résumé</div>
                    <div class="note" id="client-note">Le prix unitaire et le total sont calculés côté serveur au moment de la vérification ; cette page affiche une prévisualisation après soumission.</div>
                    <div style="margin-top:.5rem;font-weight:700">Total simulé : <span id="sim-total">-</span> €</div>
                    <div class="helper">Unités proposées :</div>
                    <div id="sim-units-placeholder"><div class="note">Après avoir cliqué sur <strong>Vérifier / Simuler</strong>, vous verrez ici le récapitulatif côté serveur.</div></div>
                </div>

                <div class="simulation-card">
                    <div class="helper">Aide</div>
                    <div class="note">Assurez-vous que la quantité demandée est disponible ; si non, le formulaire affichera une erreur.</div>
                </div>
            </aside>
        </div>
    </div>
</div>
<script>
    (function(){
        const quantityEl = document.getElementById('{{ form.quantity.vars.id }}');
        const offerEl = document.getElementById('{{ form.offer.vars.id }}');
        const availableCountEl = document.getElementById('available-count');

        if (!quantityEl) {
            return; // éléments manquants, ne pas exécuter le JS
        }

        function parseIntSafe(v) {
            const n = parseInt(v, 10);
            return Number.isNaN(n) ? 0 : n;
        }

        function updatePrice() {
            const selectedIndex = offerEl.selectedIndex;
            if (selectedIndex < 0) return;
            const selectedOption = offerEl.options[selectedIndex];
            const unitPrice = parseFloat(selectedOption.getAttribute('data-unit-price')) || 0;
            const discountPercent = parseFloat(document.getElementById('{{ form.discountPercent.vars.id }}').value) || 0;
            const annualPayment = document.getElementById('{{ form.annualPayment.vars.id }}').checked;
            let finalUnitPrice = unitPrice;

            if (discountPercent > 0) {
                finalUnitPrice = unitPrice * (1 - discountPercent / 100);
            }
            if (annualPayment) {
                finalUnitPrice *= 12*0.90; // 10% de réduction pour paiement annuel
            }

            document.getElementById('{{ form.unitPrice.vars.id }}').value = finalUnitPrice.toFixed(2);

            const quantity = parseIntSafe(quantityEl.value);
            document.getElementById('{{ form.total.vars.id }}').value = (finalUnitPrice * quantity).toFixed(2);
        }

        function updateAvailability() {
            const selectedIndex = offerEl.selectedIndex;
            if (selectedIndex < 0) return;
            const selectedOption = offerEl.options[selectedIndex];
            const offerAvailable = parseIntSafe(selectedOption.getAttribute('data-available'));
            availableCountEl.textContent = offerAvailable;
            const q = parseIntSafe(quantityEl.value);
            if (q > offerAvailable) {
                quantityEl.setCustomValidity(`La quantité demandée (${q}) dépasse la disponibilité (${offerAvailable}).`);
            } else {
                quantityEl.setCustomValidity('');
            }
        }

        offerEl.addEventListener('change', updateAvailability);
        quantityEl.addEventListener('input', updateAvailability);

        updateAvailability();
        updatePrice();
    })();
</script>
{% endblock %}
