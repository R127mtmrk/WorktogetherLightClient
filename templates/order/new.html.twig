{% extends 'base.html.twig' %}

{% block title %}Nouvelle commande{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/order.css') }}">
{% endblock %}

{% block body %}
<div class="container">
    <div class="order-card">
        <div class="order-header">
            <div>
                <div class="order-title">Nouvelle commande</div>
                <div class="order-sub">Choisissez une offre et la quantité souhaitée.</div>
            </div>
            <div class="available-badge">Dispo : <span id="available-count">{{ available }}</span></div>
        </div>

        {# Banner explaining offer selection is disabled by default #}
        {% if allow_offer_select is defined and not allow_offer_select %}
            <div class="offer-banner">
                <div class="offer-banner-inner container">
                    <strong>Sélection d'offres désactivée</strong>
                    <span>Pour choisir une offre, cliquez sur "Commander" depuis la page "Offres" ou utilisez les liens offerts par les promos.</span>
                </div>
            </div>
        {% endif %}

        <div class="form-grid">
            <div class="form-column">
                {% if compact is defined and compact and selectedOffer is defined and selectedOffer %}
                    <div class="offer-summary">
                        <h3>Offre sélectionnée : {{ selectedOffer.nameOffer }}</h3>
                        <p>Réduction : {{ selectedOffer.discountPercent ? selectedOffer.discountPercent ~ '%' : '—' }}</p>
                        <p>Quantité minimale : {{ selectedOffer.minUnits ?: '—' }}</p>
                        <p>Quantité maximale : {{ selectedOffer.maxUnits ?: '—' }}</p>
                    </div>
                {% endif %}

                {# form submitted directly to submit route to persist in one click #}
                {{ form_start(form, {'action': path('app_order_submit'), 'attr': {'id': 'order-form'}}) }}

                {% if form.offer is defined %}
                    <div class="form-row">
                        <label for="{{ form.offer.vars.id }}">Offre</label>
                        {{ form_widget(form.offer) }}
                    </div>
                {% endif %}

                <div class="form-row">
                    <label for="{{ form.quantity.vars.id }}">Quantité</label>
                    {{ form_widget(form.quantity) }}
                </div>

                <div class="form-row">
                    <label for="{{ form.paymentType.vars.id }}">Type de paiement</label>
                    {{ form_widget(form.paymentType) }}
                </div>

                <div class="form-row">
                    <label for="{{ form.annualPayment.vars.id }}">Paiement annuel</label>
                    {{ form_widget(form.annualPayment) }}
                </div>

                <div class="form-row note">
                    <label for="{{ form.unitPrice.vars.id }}">Prix unitaire (calculé)</label>
                    {{ form_widget(form.unitPrice) }}
                </div>

                <div class="form-row note">
                    <label for="{{ form.total.vars.id }}">Total (calculé)</label>
                    {{ form_widget(form.total) }}
                </div>

                {# champ pour numéro de carte requis par submit() #}
                <div class="form-row">
                    <label for="card-number">Numéro de carte</label>
                    <input type="text" id="card-number" name="card_number" placeholder="4111 1111 1111 1111" autocomplete="off" />
                    <div id="card-error" class="note" style="display:none;color:#b00;margin-top:.5rem"></div>
                </div>

                {# si compact, transmettre l'id d'offre via un champ caché pour la confirmation/submission #}
                {% if compact is defined and compact and selectedOffer is defined and selectedOffer %}
                    <input type="hidden" name="offer" value="{{ selectedOffer.id }}" />
                {% endif %}

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit" id="order-submit">Confirmer la transaction</button>
                    <a class="btn btn-ghost" href="{{ path('app_order') }}">Annuler</a>
                </div>

                {# Render discountPercent and selectedOffer as hidden widgets so they don't appear below the button as "rest" fields #}
                {% if form.discountPercent is defined %}
                    {{ form_widget(form.discountPercent, { attr: { style: 'display:none' } }) }}
                {% endif %}
                {% if form.selectedOffer is defined %}
                    {{ form_widget(form.selectedOffer, { attr: { style: 'display:none' } }) }}
                {% endif %}

                {{ form_end(form) }}

            </div>

            <aside class="side-column">
                <div class="simulation-card">
                    <div class="helper">Récapitulatif</div>
                    <div class="note" id="client-note">Le prix unitaire et le total sont calculés côté client pour faciliter la saisie, et recalculés côté serveur lors de la confirmation.</div>
                    <div style="margin-top:.5rem;font-weight:700">Total estimé : <span id="sim-total">-</span> €</div>
                    <div class="helper">Unités proposées :</div>
                    <div id="sim-units-placeholder"><div class="note">Le détail des unités allouées sera affiché après confirmation.</div></div>
                </div>

                <div class="simulation-card">
                    <div class="helper">Aide</div>
                    <div class="note">Assurez-vous que la quantité demandée est disponible ; si non, la soumission sera rejetée et un message d'erreur s'affichera.</div>
                </div>
            </aside>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>window.ORDER_BASE_UNIT_PRICE = '10.00';</script>
    <script src="{{ asset('js/order.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function(){
            window.OrderUI.init({
                quantityId: '{{ form.quantity.vars.id }}',
                unitPriceId: '{{ form.unitPrice.vars.id }}',
                totalId: '{{ form.total.vars.id }}',
                discountId: '{{ form.discountPercent.vars.id }}',
                annualId: '{{ form.annualPayment.vars.id }}',
                offerSelectId: '{{ form.offer is defined ? form.offer.vars.id : '' }}',
                availableId: 'available-count',
                cardId: 'card-number',
                formId: 'order-form',
                submitBtnId: 'order-submit',
                cardErrorId: 'card-error'
            });
        });
    </script>
{% endblock %}
{% endblock %}
