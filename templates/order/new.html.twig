{% extends 'base.html.twig' %}

{% block title %}Nouvelle commande{% endblock %}

{% block body %}
    <h1>Nouvelle commande</h1>

    <p>Unités disponibles : <strong id="available-count">{{ available }}</strong></p>

    {{ form_start(form, {'attr': {'id': 'order-form'}}) }}
        {{ form_row(form.offer) }}
        {{ form_row(form.quantity) }}
        {{ form_row(form.unitPrice) }}
        {{ form_row(form.annualPayment) }}
        {{ form_row(form.discountPercent) }}
        {{ form_row(form.total) }}
        {{ form_row(form.createdAt) }}
        {{ form_row(form.simulate) }}

        <button type="submit">Commander</button>
    {{ form_end(form) }}

    {% if simulate is defined and simulate %}
        <h2>Résultat de la simulation</h2>
        <p>Total simulé : {{ simulatedTotal ?? '-' }} €</p>
        <p>Unités proposées :</p>
        {% if simulatedUnits is defined and simulatedUnits is not empty %}
            <ul>
                {% for id in simulatedUnits %}
                    <li>Unit #{{ id }}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>Aucune unité proposée.</p>
        {% endif %}
    {% endif %}

    {% block javascripts %}
        {{ parent() }}
        <script>
            (function(){
                const offerSelect = document.querySelector('#{{ form.offer.vars.id }}');
                const availableEl = document.getElementById('available-count');

                if (offerSelect) {
                    offerSelect.addEventListener('change', function () {
                        const val = this.value;
                        if (!val) {
                            return;
                        }
                        fetch('{{ path('app_order_available', {'id': 'REPLACE_ID'}) }}'.replace('REPLACE_ID', val))
                            .then(resp => resp.json())
                            .then(data => {
                                if (data && typeof data.available !== 'undefined') {
                                    availableEl.textContent = data.available;
                                }
                            })
                            .catch(() => {
                                // ignore network errors silently
                            });
                    });
                }

                // Intercepte la soumission du formulaire et redirige vers /order/confirm via POST
                const form = document.getElementById('order-form');
                if (!form) return;

                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    // Créer un form POST dynamique
                    const confirmForm = document.createElement('form');
                    confirmForm.method = 'POST';
                    confirmForm.action = '{{ path('app_order_confirm') }}';

                    // récupérer tous les champs pertinents
                    const fields = ['{{ form.offer.vars.name }}', '{{ form.quantity.vars.name }}', '{{ form.unitPrice.vars.name }}', '{{ form.annualPayment.vars.name }}', '{{ form.discountPercent.vars.name }}', '{{ form.total.vars.name }}', '{{ form.createdAt.vars.name }}', '{{ form.simulate.vars.name }}'];

                    fields.forEach(name => {
                        const el = form.querySelector('[name="' + name + '"]');
                        if (!el) return;

                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = el.name;
                        if (el.type === 'checkbox') {
                            input.value = el.checked ? '1' : '0';
                        } else {
                            input.value = el.value;
                        }
                        confirmForm.appendChild(input);
                    });

                    document.body.appendChild(confirmForm);
                    confirmForm.submit();
                });
            })();
        </script>
    {% endblock %}

{% endblock %}
