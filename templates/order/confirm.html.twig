{% extends 'base.html.twig' %}

{% block title %}Confirmation de la commande{% endblock %}

{% block body %}
    <h1>Confirmation de la commande</h1>

    <div id="loading" style="border:1px solid #ccc;padding:1rem;margin-bottom:1rem;">
        <p>Préparation de la transaction...</p>
        <p>Offre : {{ offer ? offer.id : '-' }}</p>
        <p>Quantité : {{ quantity }}</p>
        <p>Unités disponibles : <strong>{{ available }}</strong></p>
        <p>Total : {{ total }} €</p>
    </div>

    {% for label, messages in app.flashes %}
        {% if label == 'card_error' %}
            <div style="color:#b00;margin-bottom:1rem;">{{ messages[0] }}</div>
        {% endif %}
    {% endfor %}

    <form method="post" action="{{ path('app_order_submit') }}" id="confirm-form">
        <input type="hidden" name="offer" value="{{ offer ? offer.id : '' }}" />
        <input type="hidden" name="quantity" value="{{ quantity }}" />
        <input type="hidden" name="unitPrice" value="{{ unitPrice }}" />
        <input type="hidden" name="annualPayment" value="{{ annualPayment ? 1 : 0 }}" />
        <input type="hidden" name="discountPercent" value="{{ discountPercent }}" />
        <input type="hidden" name="total" value="{{ total }}" />

        <div style="margin:1rem 0;">
            <label for="card-number">Numéro de carte</label>
            <input type="text" id="card-number" name="card_number" placeholder="1234 5678 9123 4567" autocomplete="off" />
            <div id="card-error" style="color:#b00;margin-top:.5rem;display:none;"></div>
        </div>

        <button type="submit" id="confirm-btn">Confirmer la transaction</button>
        <a href="{{ path('app_order_new') }}">Annuler</a>
    </form>

    {% if units is defined and units is not empty %}
        <h2>Unités proposées</h2>
        <ul>
            {% for id in units %}
                <li>Unit #{{ id }}</li>
            {% endfor %}
        </ul>
    {% endif %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/order.js') }}"></script>
{% endblock %}

{% endblock %}
