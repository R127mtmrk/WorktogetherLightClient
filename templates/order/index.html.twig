{% extends 'base.html.twig' %}

{% block title %}Mes commandes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/order.css') }}">
    <link rel="stylesheet" href="{{ asset('css/orders-list.css') }}">
{% endblock %}

{% block body %}
<div class="container">
    <div class="orders-header" style="display:flex;justify-content:space-between;align-items:center;margin:1.2rem 0;">
        <div>
            <h1>Mes commandes</h1>
            <p class="muted">Historique des commandes passées et statut des unités.</p>
        </div>
        <div>
            <a class="btn btn-primary" href="{{ path('app_order_new') }}">Nouvelle commande</a>
        </div>
    </div>

    {% if orders is empty %}
        <div class="card" style="padding:1.2rem;">
            <strong>Aucune commande trouvée.</strong>
            <p class="note">Vous n'avez encore passé aucune commande. Cliquez sur "Nouvelle commande" pour commencer.</p>
        </div>
    {% else %}
        <div class="card">
            <table class="orders-table" style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr style="text-align:left;border-bottom:1px solid #ddd;">
                        <th>#</th>
                        <th>Date</th>
                        <th>Client</th>
                        <th>Offre</th>
                        <th>Prix unitaire</th>
                        <th>Total</th>
                        <th>Unités allouées</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr style="border-bottom:1px solid rgba(0,0,0,0.05);">
                            <td data-label="#">{{ order.id }}</td>
                            <td data-label="Client">{{ order.client ? (order.client.getEmail()) : '-' }}</td>
                            <td data-label="Date">{{ order.createdAt ? order.createdAt|date('Y-m-d H:i') : '-' }}</td>
                            <td data-label="Offre">
                                {% if order.offer %}
                                    Offre {{ order.offer.id }}
                                    {% if order.offer.getDiscountPercent() is not null %}
                                        — {{ order.offer.getDiscountPercent() }} %
                                    {% endif %}
                                {% else %}
                                    Aucune
                                {% endif %}
                            </td>
                            <td data-label="Prix unitaire">{{ order.unitPrice is not null ? order.unitPrice ~ ' €' : '-' }}</td>
                            <td class="total" data-label="Total">{{ order.total is not null ? order.total ~ ' €' : '-' }}</td>
                            <td data-label="Unités">{{ order.units|length }}</td>
                            <td data-label="Statut">
                                {{ order.state }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
