{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="logo" aria-hidden="true"></span>
      <h1>WorkTogether</h1>
    </div>

    {% if error %}
      <div class="form-errors">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <p class="auth-sub">Connectez-vous pour gérer vos commandes et unités.</p>

    <form method="post" action="{{ path('app_login') }}">
        <div class="form-row">
            <label for="username">Email</label>
            <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus />
        </div>

        <div class="form-row">
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="_password" required />
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="form-actions">
            <button class="btn" type="submit">Se connecter</button>
            <a class="btn-outline" href="{{ path('app_register') }}">Créer un compte</a>
        </div>
    </form>

    <div class="footer-note">Mot de passe oublié ? contactez l'administrateur.</div>
  </div>
</div>
{% endblock %}
