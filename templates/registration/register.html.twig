{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block title %}Inscription{% endblock %}

{# enlever la navbar sur la page d'inscription #}
{% block navbar %}{% endblock %}

{% block body %}
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="logo" aria-hidden="true"></span>
      <h1>Créer un compte</h1>
    </div>

    {{ form_start(registrationForm) }}
        <div class="form-row">
            {{ form_label(registrationForm.pseudo) }}
            {{ form_widget(registrationForm.pseudo) }}
        </div>

        <div class="form-row">
            {{ form_label(registrationForm.email) }}
            {{ form_widget(registrationForm.email) }}
        </div>

        <div class="form-row">
            {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
            {{ form_widget(registrationForm.plainPassword) }}
        </div>

        <div class="form-row">
            {{ form_widget(registrationForm.agreeTerms) }}
            {{ form_label(registrationForm.agreeTerms) }}
        </div>

        <div class="form-actions">
            <button class="btn" type="submit">S'inscrire</button>
            <a class="btn-outline" href="{{ path('app_login') }}">Se connecter</a>
        </div>

    {{ form_end(registrationForm) }}

    <div class="footer-note">En vous inscrivant, vous acceptez nos conditions.</div>
  </div>
</div>
{% endblock %}
